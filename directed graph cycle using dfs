class Solution:
    def isCyclic(self, V, edges):
        adj = [[] for i in range(V)]
        for u, v in edges:
            adj[u].append(v)

        vis = [False] * V
        pv = [False] * V

        def dfs(node):
            vis[node] = True
            pv[node] = True

            for nei in adj[node]:
                if not vis[nei]:
                    if dfs(nei):
                        return True
                elif pv[nei]:
                    return True

            pv[node] = False
            return False

        for i in range(V):
            if not vis[i]:
                if dfs(i):
                    return True

        return False
